html
@{
    ViewData["Title"] = "Все аниме";
}
@model AnimeListViewModel

<div class="container">
    <h1>Все аниме сезона</h1>
    
    <div class="filter-section">
        <form method="get">
            <select name="genre">
                <option value="">Все жанры</option>
                @foreach (var genre in Model.Genres)
                {
                    <option value="@genre" selected="@(Model.SelectedGenre == genre ? "selected" : null)">
                        @genre
                    </option>
                }
            </select>
            <button type="submit">Фильтровать</button>
            <a href="/Anime" class="btn-reset">Сбросить</a>
        </form>
        <span class="total-count">Найдено: @Model.TotalItems</span>
    </div>

    <div class="anime-grid">
        @foreach (var anime in Model.AnimeList)
        {
            <div class="anime-card">
                <div class="card-image">
                    @if (!string.IsNullOrEmpty(anime.PosterUrl))
                    {
                        <img src="@anime.PosterUrl" alt="@anime.Title" />
                    }
                    else
                    {
                        <div class="placeholder">🎬</div>
                    }
                </div>
                <div class="card-content">
                    <h3><a href="/Anime/Details/@anime.Id">@anime.Title</a></h3>
                    <span class="genre">@anime.Genre</span>
                    <div class="rating">⭐ @anime.Rating.ToString("F1")/10</div>
                    <div class="release-date">📅 @anime.ReleaseDate.ToString("dd.MM.yyyy")</div>
                </div>
            </div>
        }
    </div>

    <div class="pagination">
        @if (Model.CurrentPage > 1)
        {
            <a href="?page=@(Model.CurrentPage - 1)&genre=@Model.SelectedGenre">◀ Назад</a>
        }
        
        <span>Страница @Model.CurrentPage из @Model.TotalPages</span>
        
        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a href="?page=@(Model.CurrentPage + 1)&genre=@Model.SelectedGenre">Вперед ▶</a>
        }
    </div>
</div>
